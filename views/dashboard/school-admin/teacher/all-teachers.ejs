<!doctype html>
<html class="no-js" lang="ar">
<%- include('../../../partials/head.ejs') %>

<body class="rtl">
<div class="bmd-layout-container bmd-drawer-f-l avam-container animated bmd-drawer-in">

  <%- include('../../../partials/header.ejs') %>
  <div id="dw-s1" class="bmd-layout-drawer bg-faded">
    <%- include('../../../partials/sidebar/index.ejs') %>
  </div>

  <main class="bmd-layout-content">
    <div class="container-fluid">

      <!-- Breadcrumb -->
      <div class="row m-1 pb-4 mb-3">
        <div class="col-12 p-2">
          <div class="page-header breadcrumb-header d-flex justify-content-between align-items-end">
            <div>
              <h3 class="lite-text">جميع المدرسين</h3>
              <span class="lite-text text-gray">عرض كل المدرسين في المدرسة</span>
            </div>
            <div>
              <a href="/school-admin/teachers/create" class="btn btn-success">
                <i class="fas fa-plus"></i> إضافة مدرس
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- 🔍 Search -->
      <div class="row m-1 mb-3">
        <div class="col-md-6">
          <input
            type="text"
            id="teacherSearch"
            class="form-control"
            placeholder="ابحث بالاسم أو الفصل أو المادة..."
          >
        </div>
      </div>


      <!-- Flash Messages -->
      <% if (locals.error && locals.error.length > 0) { %>
        <div class="alert alert-danger"><%= locals.error %></div>
      <% } %>
      <% if (locals.success && locals.success.length > 0) { %>
        <div class="alert alert-success"><%= locals.success %></div>
      <% } %>

      <!-- Table -->
      <div class="row m-1">
        <div class="col-12 p-2">
          <div class="card shade h-100">
            <div class="card-body table-responsive">
              <table class="table table-bordered table-hover text-center" id="teachersTable">
                <thead class="thead-light">
                  <tr>
                    <th>#</th>
                    <th>الاسم</th>
                    <th>البريد الإلكتروني</th>
                    <th>الفصول</th>
                    <th>المواد</th>
                    
                    <th>العمليات</th>
                  </tr>
                </thead>
                <tbody>
                  <% if(teachers.length === 0){ %>
                    <tr><td colspan="7">لا يوجد مدرسين مضافين</td></tr>
                  <% } %>

                  <% teachers.forEach((teacher, index) => { %>
                    <!-- الصف الرئيسي -->
                    <tr class="main-row" data-teacher-id="<%= teacher._id %>"
                        data-name="<%= teacher.name.toLowerCase() %>"
                        data-classes="<%= teacher.classes.map(c => c.name).join(' ').toLowerCase() %>"
                        data-subjects="<%= teacher.subjects.map(s => s.name).join(' ').toLowerCase() %>"
                    >
                      <td><%= index + 1 %></td>
                      <td><%= teacher.name %></td>
                      <td><%= teacher.email %></td>
                      <td>
                        <% teacher.classes.forEach(cls => { %>
                          <span class="badge badge-info"><%= cls.name %></span>
                        <% }) %>
                      </td>
                      <td>
                        <% teacher.subjects.forEach(sub => { %>
                          <span class="badge badge-success"><%= sub.name %></span>
                        <% }) %>
                      </td>
                      <td class="d-flex justify-content-center flex-wrap gap-1">
                        <button class="btn btn-sm btn-primary toggle-details">عرض</button>
                        <a href="/school-admin/teachers/<%= teacher._id %>/edit" class="btn btn-sm btn-warning">تعديل</a>
                         <!-- زر الحذف الجديد -->
  <button 
    class="btn btn-sm btn-danger delete-btn"
    data-id="<%= teacher._id %>"
    data-name="<%= teacher.name %>"
  >
    حذف
  </button>
                      </td>
                    </tr>

                    <!-- صف التفاصيل المخفي -->
                    <tr class="details-row" style="display:none;">
                      <td colspan="7" class="text-left">
                        <strong>الهاتف:</strong> <%= teacher.phone || '—' %><br>
                       <strong>الشعب:</strong>
<% teacher.sections.forEach(sec => { %>
  <span class="badge badge-secondary">
    <%= sec.classId ? sec.classId.name + ' - ' : '' %><%= sec.name %>
  </span>
<% }) %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>
<!-- مودال تأكيد الحذف -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content text-right">
      
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">تأكيد الحذف</h5>
        <button type="button" class="close text-white" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>

      <div class="modal-body">
        هل أنت متأكد من حذف المدرس:
        <strong id="teacherName"></strong> ؟
      </div>

      <div class="modal-footer">
        <form id="deleteForm" method="POST">
          <!-- إذا كنت تستخدم method-override -->
          <input type="hidden" name="_method" value="DELETE">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <button type="button" class="btn btn-secondary" data-dismiss="modal">
            إلغاء
          </button>
          <button type="submit" class="btn btn-danger">
            نعم، حذف
          </button>
        </form>
      </div>

    </div>
  </div>
</div>


<%- include('../../../partials/scripts.ejs') %>

<script>
  // 🔍 البحث الفوري
  document.getElementById('teacherSearch').addEventListener('keyup', function () {
    const searchValue = this.value.toLowerCase();
    const rows = document.querySelectorAll('#teachersTable tbody tr.main-row');

    rows.forEach(row => {
      const name = row.dataset.name || '';
      const classes = row.dataset.classes || '';
      const subjects = row.dataset.subjects || '';

      const match =
        name.includes(searchValue) ||
        classes.includes(searchValue) ||
        subjects.includes(searchValue);

      row.style.display = match ? '' : 'none';
      const detailsRow = row.nextElementSibling;
      if(detailsRow && detailsRow.classList.contains('details-row')){
        detailsRow.style.display = 'none';
        row.querySelector('.toggle-details').textContent = 'عرض';
      }
    });
  });

  // 🔽 زر عرض التفاصيل لكل مدرس
  document.querySelectorAll('.toggle-details').forEach(btn => {
    btn.addEventListener('click', function(){
      const mainRow = this.closest('tr');
      const detailsRow = mainRow.nextElementSibling;
      if(detailsRow.style.display === 'none'){
        detailsRow.style.display = '';
        this.textContent = 'إخفاء';
      } else {
        detailsRow.style.display = 'none';
        this.textContent = 'عرض';
      }
    });
  });

  // زر الحذف
document.querySelectorAll('.delete-btn').forEach(btn => {
  btn.addEventListener('click', function () {
    const teacherId = this.dataset.id;
    const teacherName = this.dataset.name;

    // وضع الاسم داخل المودال
    document.getElementById('teacherName').textContent = teacherName;

    // تعديل رابط الفورم
    const form = document.getElementById('deleteForm');
    form.action = `/school-admin/teachers/${teacherId}?_method=DELETE`;

    // فتح المودال
    $('#deleteModal').modal('show');
  });
});

</script>

</body>
</html>
