<main class="bmd-layout-content">
  <div class="container-fluid">
    <!-- Header -->
    <div class="row m-1 pb-4 mb-3">
      <div class="col-12 p-2">
        <div class="page-header breadcrumb-header">
          <div class="row align-items-end">
            <div class="col-lg-8">
              <div class="page-header-title text-left-rtl">
                <h3 class="lite-text">لوحة التحكم</h3>
                <span class="lite-text text-gray">مرحباً بك في نظام الإدارة</span>
              </div>
            </div>
            <div class="col-lg-4">
              <ol class="breadcrumb float-sm-right">
                <li class="breadcrumb-item"><a href="#"><i class="fas fa-home"></i></a></li>
                <li class="breadcrumb-item active">Dashboard</li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Welcome message for teacher or attendance staff -->
    <% if(user.role === 'teacher' || user.role === 'attendance-staff') { %>
      <div class="row m-1">
        <div class="col-12 p-2">
          <div class="card shade">
            <div class="card-body text-center">
              <h4>مرحباً <%= user.fullName %>!</h4>
              <p>سيتم عرض الإحصائيات الخاصة بك هنا قريباً.</p>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Welcome message for parent -->
    <% if(user.role === 'parent' || user.role === 'parent') { %>
      <div class="row m-1">
        <div class="col-12 p-2">
          <div class="card shade">
            <div class="card-body text-center">
              <h4>مرحباً!</h4>
              <p>سيتم عرض الإحصائيات الخاصة بك هنا قريباً.</p>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Existing dashboard for other roles remains intact -->
    <% if(user.role === 'super-admin' || user.role === 'school-admin' || user.role === 'school-coordinator') { %>
      <div class="row m-1 mb-2">
        <% if(user.role === 'super-admin') { %>
          <div class="col-xl-3 col-lg-4 col-md-6 p-2">
            <div class="super-admin-stat-card stat-schools">
              <div class="super-admin-stat-icon"><i class="fas fa-school"></i></div>
              <div class="super-admin-stat-label">عدد المدارس</div>
              <div class="super-admin-stat-value"><%= stats.totalSchools %></div>
              <div class="super-admin-stat-meta">إجمالي المدارس المسجلة في النظام</div>
            </div>
          </div>
          <div class="col-xl-3 col-lg-4 col-md-6 p-2">
            <div class="super-admin-stat-card stat-suppliers">
              <div class="super-admin-stat-icon"><i class="fas fa-truck-loading"></i></div>
              <div class="super-admin-stat-label">عدد الموردين</div>
              <div class="super-admin-stat-value"><%= stats.totalSuppliers %></div>
              <div class="super-admin-stat-meta">الموردون المعتمدون داخل النظام</div>
            </div>
          </div>
          <div class="col-xl-3 col-lg-4 col-md-6 p-2">
            <button
              type="button"
              class="super-admin-stat-card dashboard-students-card stat-students"
              data-toggle="modal"
              data-target="#studentsBySchoolModal"
            >
              <div class="super-admin-stat-icon"><i class="fas fa-user-graduate"></i></div>
              <div class="super-admin-stat-label">إجمالي الطلاب</div>
              <div class="super-admin-stat-value"><%= stats.totalStudents || 0 %></div>
              <div class="super-admin-stat-meta">اضغط لعرض التفصيل حسب كل مدرسة</div>
            </button>
          </div>
          <div class="col-xl-3 col-lg-6 col-md-6 p-2">
            <div class="super-admin-stat-card stat-incomes">
              <div class="super-admin-stat-icon"><i class="fas fa-arrow-down"></i></div>
              <div class="super-admin-stat-label">إجمالي الواردات</div>
              <div class="super-admin-stat-value"><%= stats.totalIncomes[0]?.total || 0 %></div>
              <div class="super-admin-stat-meta">مجموع الواردات على مستوى المؤسسة</div>
            </div>
          </div>
          <div class="col-xl-3 col-lg-6 col-md-6 p-2">
            <div class="super-admin-stat-card stat-expenses">
              <div class="super-admin-stat-icon"><i class="fas fa-arrow-up"></i></div>
              <div class="super-admin-stat-label">إجمالي الصادرات</div>
              <div class="super-admin-stat-value"><%= stats.totalExpenses[0]?.total || 0 %></div>
              <div class="super-admin-stat-meta">مجموع الصادرات على مستوى المؤسسة</div>
            </div>
          </div>
        <% } else if(user.role === 'school-admin' || user.role === 'school-coordinator') { %>
          <div class="col-md-4 p-2">
            <div class="box-card mini"><span>إجمالي الواردات للمدرسة</span><span><%= stats.totalIncomes[0]?.total || 0 %></span></div>
          </div>
          <div class="col-md-4 p-2">
            <div class="box-card mini"><span>إجمالي الصادرات للمدرسة</span><span><%= stats.totalExpenses[0]?.total || 0 %></span></div>
          </div>
          <div class="col-md-4 p-2">
            <div class="box-card mini"><span>عدد المعلمين</span><span><%= stats.totalTeachers %></span></div>
          </div>
        <% } %>
      </div>
    <% } %>

    <% if(user.role === 'super-admin') { %>
      <div class="modal fade" id="studentsBySchoolModal" tabindex="-1" role="dialog" aria-labelledby="studentsBySchoolModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
          <div class="modal-content students-modal">
            <div class="modal-header border-0 pb-0">
              <div>
                <h5 class="modal-title" id="studentsBySchoolModalLabel">تفصيل الطلاب حسب المدرسة</h5>
                <p class="students-modal-subtitle mb-0">إجمالي الطلاب المسجلين في جميع المدارس: <strong><%= stats.totalStudents || 0 %></strong></p>
              </div>
              <button type="button" class="close ml-0 mr-auto" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>

            <div class="modal-body pt-3">
              <% if (stats.studentsBySchool?.length) { %>
                <div class="students-school-list">
                  <% stats.studentsBySchool.forEach((school, index) => { %>
                    <div class="students-school-item">
                      <div class="students-school-rank"><%= index + 1 %></div>
                      <div class="students-school-content">
                        <h6><%= school.name %></h6>
                        <p>عدد الطلاب المسجلين</p>
                      </div>
                      <div class="students-school-count"><%= school.studentCount %></div>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="alert alert-light text-center mb-0">
                  لا توجد بيانات طلاب مسجلة حالياً.
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</main>
